# Neon PostgreSQL connection string
# Currently requires Neon — create a free project at https://neon.tech
# Copy the connection string from your Neon project dashboard
NEON_DATABASE_URL=postgresql://user:password@host/dbname

# JWT secret for admin token signing
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Super admin key for internal platform management
# Generate with: openssl rand -hex 32
SUPER_ADMIN_KEY=
